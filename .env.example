# ── Required ──────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Use a long, random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# ── Optional ──────────────────────────────────────────────────────────────────
# The public URL of your deployment (used in invite share links).
# Railway sets this automatically if you link a custom domain.
# Example: https://peekboard.up.railway.app
APP_URL=https://your-app.up.railway.app

# Port the server listens on. Railway sets this automatically.
PORT=3001

# Set to "production" on Railway (Railway sets this automatically).
NODE_ENV=production
